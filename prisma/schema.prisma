generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SALES_MANAGER
  SALES_AGENT
}

enum NotificationType {
  LEAD_MENTION
  LEAD_COMMENT
  DIRECT_MESSAGE
}

model User {
  id                          String                       @id @default(cuid())
  googleId                    String                       @unique
  email                       String                       @unique
  name                        String?
  image                       String?
  role                        UserRole                     @default(SALES_AGENT)
  imports                     LeadImport[]
  leadComments                LeadComment[]
  leadCommentMentions         LeadCommentMention[]
  conversationsAsParticipant1 Conversation[]               @relation("ConversationP1")
  conversationsAsParticipant2 Conversation[]               @relation("ConversationP2")
  directMessages              DirectMessage[]
  notificationsReceived       Notification[]               @relation("NotificationRecipient")
  notificationsSent           Notification[]               @relation("NotificationActor")
  notificationPreferences     UserNotificationPreferences?
  dailyTargets                DailyTarget[]
  leadStageTransitions        LeadStageTransition[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
}

enum FieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  URL
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  CHECKBOX
}

enum CampaignStatus {
  ACTIVE
  ARCHIVED
}

enum ImportStatus {
  UPLOADED
  ANALYZED
  COMMITTED
  FAILED
}

model CampaignType {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  fields      CampaignTypeField[]
  campaigns   Campaign[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model CampaignTypeField {
  id               String           @id @default(cuid())
  campaignTypeId   String
  campaignType     CampaignType     @relation(fields: [campaignTypeId], references: [id], onDelete: Cascade)
  key              String
  label            String
  fieldType        FieldType
  required         Boolean          @default(false)
  showOnKanbanCard Boolean          @default(false)
  isUnique         Boolean          @default(false)
  sortOrder        Int              @default(0)
  options          Json?
  fieldValues      LeadFieldValue[]

  @@unique([campaignTypeId, key])
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  campaignTypeId String
  campaignType   CampaignType   @relation(fields: [campaignTypeId], references: [id], onDelete: Restrict)
  stages         LeadStage[]
  leads          Lead[]
  imports        LeadImport[]
  status         CampaignStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model LeadStage {
  id              String                @id @default(cuid())
  campaignId      String
  campaign        Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  sortOrder       Int                   @default(0)
  color           String?
  isDefault       Boolean               @default(false)
  leads           Lead[]                @relation("LeadCurrentStage")
  dailyTargets    DailyTarget[]
  transitionsFrom LeadStageTransition[] @relation("TransitionFromStage")
  transitionsTo   LeadStageTransition[] @relation("TransitionToStage")

  @@unique([campaignId, slug])
}

model Lead {
  id               String                @id @default(cuid())
  campaignId       String
  campaign         Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  currentStageId   String
  currentStage     LeadStage             @relation("LeadCurrentStage", fields: [currentStageId], references: [id], onDelete: Restrict)
  fieldValues      LeadFieldValue[]
  comments         LeadComment[]
  sourceImportId   String?
  sourceImport     LeadImport?           @relation(fields: [sourceImportId], references: [id], onDelete: SetNull)
  stageTransitions LeadStageTransition[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model LeadFieldValue {
  id      String            @id @default(cuid())
  leadId  String
  lead    Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fieldId String
  field   CampaignTypeField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value   Json

  @@unique([leadId, fieldId])
}

model LeadImport {
  id           String       @id @default(cuid())
  fileName     String
  fileType     String
  rowCount     Int
  status       ImportStatus @default(UPLOADED)
  analysis     Json?
  mapping      Json?
  campaignId   String?
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads        Lead[]
  errorMessage String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model LeadComment {
  id        String               @id @default(cuid())
  leadId    String
  lead      Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime             @default(now())
  mentions  LeadCommentMention[]

  @@index([leadId, createdAt])
}

model LeadCommentMention {
  id        String      @id @default(cuid())
  commentId String
  comment   LeadComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model Conversation {
  id             String          @id @default(cuid())
  participant1Id String
  participant2Id String
  participant1   User            @relation("ConversationP1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2   User            @relation("ConversationP2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages       DirectMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([updatedAt])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  @@index([conversationId, createdAt])
  @@index([conversationId, senderId, readAt])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType
  leadId         String?
  commentId      String?
  conversationId String?
  messageId      String?
  actorId        String
  actor          User             @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  preview        String
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  @@index([userId, readAt, createdAt])
}

model UserNotificationPreferences {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  browserEnabled Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}

model DailyTarget {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  leadStageId String
  leadStage   LeadStage @relation(fields: [leadStageId], references: [id], onDelete: Cascade)
  targetCount Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, leadStageId])
}

model LeadStageTransition {
  id          String     @id @default(cuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStageId String?
  fromStage   LeadStage? @relation("TransitionFromStage", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStageId   String
  toStage     LeadStage  @relation("TransitionToStage", fields: [toStageId], references: [id], onDelete: Restrict)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([userId, toStageId, createdAt])
}
